<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= user.name %> | LinkPage</title>
    <link rel="stylesheet" href="/css/minimal.css">
    <style>
        :root {
            --bg-color: #fcfcfc;
            --text-main: #1a1a1a;
            --text-secondary: #666;
            --button-bg: #151019; /* Your original deep purple/black */
            --button-text: #ffffff;
            --hover-scale: 1.02;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            min-height: 100vh;
        }

        .container {
            width: 100%;
            max-width: 580px;
            padding: 60px 20px;
            text-align: center;
        }

        .profile {
            margin-bottom: 32px;
        }

        .profile img {
            width: 96px;
            height: 96px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #eee;
            margin-bottom: 16px;
        }

        .profile h1 {
            font-size: 20px;
            font-weight: 600;
            letter-spacing: -0.02em;
            margin: 0;
        }

        .profile p {
            font-size: 15px;
            color: var(--text-secondary);
            margin-top: 8px;
            line-height: 1.5;
        }

        .links {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .links a {
            display: block;
            padding: 18px 24px;
            background-color: var(--button-bg);
            color: var(--button-text);
            text-decoration: none;
            border-radius: 12px;
            font-weight: 500;
            font-size: 16px;
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.2s;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        }

        .links a:hover {
            transform: scale(var(--hover-scale));
            filter: brightness(1.2);
        }

        /* Footer / Brand Link */
        .footer {
            margin-top: 60px;
            font-size: 12px;
            color: #ccc;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="profile">
            <% if (user.profileImage) { %>
                <img src="<%= user.profileImage %>" alt="<%= user.name %>">
            <% } else { %>
                <img src="/images/default-profile.png" alt="Default Profile">
            <% } %>
            <h1><%= user.name %></h1>
            <% if (user.bio) { %>
                <p><%= user.bio %></p>
            <% } %>
        </div>

        <div class="links">
            <% if (user.links && user.links.length > 0) { %>
                <% user.links.forEach(link => { %>
                    <a href="<%= link.url %>" target="_blank" rel="noopener">
                        <%= link.title %>
                    </a>
                <% }) %>
            <% } else { %>
                <p style="color: #999;">No links shared yet.</p>
            <% } %>
        </div>

        <div class="footer">
            Created with LinkPage
        </div>
    </div>
</body>
</html>